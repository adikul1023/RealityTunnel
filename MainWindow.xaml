<Window
    x:Class="RealityTunnel.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="OverREALITY">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </Window.SystemBackdrop>

    <Grid>
        <!-- Drag handle: top bar -->
        <Grid x:Name="TitleBar" Height="32" VerticalAlignment="Top"
              Background="Transparent" PointerPressed="TitleBar_PointerPressed">
            <TextBlock Text="OverREALITY" VerticalAlignment="Center"
                       Margin="12,0" FontSize="11" Opacity="0.5"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
            <!-- Minimise to tray -->
            <Button x:Name="MinimiseButton" Content="⊟" HorizontalAlignment="Right"
                    VerticalAlignment="Center" Margin="0,0,4,0"
                    Background="Transparent" BorderBrush="Transparent" FontSize="14"
                    Click="MinimiseButton_Click" />
        </Grid>

        <!-- Main content -->
        <StackPanel Orientation="Vertical" Margin="12,40,12,12" Spacing="10">

            <!-- Status orb + label -->
            <Grid HorizontalAlignment="Center">
                <Ellipse x:Name="StatusOrb" Width="64" Height="64"
                         Fill="#33FFFFFF" />
                <Ellipse x:Name="StatusOrbGlow" Width="48" Height="48"
                         Fill="#44808080" />
                <TextBlock x:Name="StatusIcon" Text="●" FontSize="28"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="#80808080" />
            </Grid>

            <TextBlock x:Name="StatusLabel" Text="Disconnected"
                       HorizontalAlignment="Center" FontSize="13" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}" />

            <TextBlock x:Name="TimerLabel" Text="" HorizontalAlignment="Center"
                       FontSize="11" Opacity="0.55"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}" />

            <!-- Divider -->
            <Rectangle Height="1" Fill="#22FFFFFF" Margin="0,2" />

            <!-- Server IP -->
            <TextBlock Text="SERVER IP" FontSize="10" Opacity="0.5" Margin="0,2,0,0"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
            <TextBox x:Name="ServerIpTextBox"
                     PlaceholderText="e.g. 1.2.3.4"
                     FontSize="13"
                     Background="#18FFFFFF"
                     BorderBrush="#30FFFFFF"
                     CornerRadius="8" />

            <!-- Connect / Disconnect -->
            <Button x:Name="ConnectButton" Content="Connect"
                    HorizontalAlignment="Stretch" Click="ConnectButton_Click"
                    CornerRadius="8" FontWeight="SemiBold" FontSize="13"
                    Background="#CC0078D4" Foreground="White"
                    BorderBrush="Transparent" Padding="0,10" />

            <Button x:Name="DisconnectButton" Content="Disconnect"
                    HorizontalAlignment="Stretch" Click="DisconnectButton_Click"
                    IsEnabled="False" CornerRadius="8" FontSize="13"
                    Background="#22FFFFFF" Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                    BorderBrush="#30FFFFFF" Padding="0,10" />

            <!-- Dashboard stats -->
            <Rectangle Height="1" Fill="#22FFFFFF" Margin="0,2" />

            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
                <TextBlock Grid.Column="0" Grid.Row="0" Text="EXIT IP"
                           FontSize="9" Opacity="0.45" Margin="0,0,0,2"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                <TextBlock Grid.Column="1" Grid.Row="0" Text="STATUS"
                           FontSize="9" Opacity="0.45" Margin="8,0,0,2"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                <TextBlock x:Name="ExitIpLabel" Grid.Column="0" Grid.Row="1"
                           Text="—" FontSize="11" FontWeight="SemiBold"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                <TextBlock x:Name="RetryLabel" Grid.Column="1" Grid.Row="1"
                           Text="—" FontSize="11" Margin="8,0,0,0"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
            </Grid>

        </StackPanel>
    </Grid>
</Window>
