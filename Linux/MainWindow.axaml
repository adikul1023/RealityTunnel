<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OverREALITY.Linux.MainWindow"
        Title="OverREALITY"
        Width="280" Height="440"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        Background="#0A081E"
        FontFamily="Inter,sans-serif">

  <Window.Styles>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="#0078D4"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="0,10"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="Button.secondary">
      <Setter Property="Background" Value="#1E1E2E"/>
      <Setter Property="Foreground" Value="#AAAACC"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="0,10"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="TextBox">
      <Setter Property="Background" Value="#12102A"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="BorderBrush" Value="#2A2848"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="10,8"/>
    </Style>
  </Window.Styles>

  <StackPanel Margin="24" Spacing="0">

    <!-- Header -->
    <TextBlock Text="OverREALITY"
               FontSize="20" FontWeight="Bold"
               Foreground="White"
               HorizontalAlignment="Center"
               Margin="0,0,0,4"/>
    <TextBlock x:Name="StatusLabel"
               Text="Disconnected"
               FontSize="12"
               Foreground="#888888"
               HorizontalAlignment="Center"
               Margin="0,0,0,20"/>

    <!-- Status orb -->
    <Grid HorizontalAlignment="Center" Margin="0,0,0,20"
          Width="72" Height="72">
      <Ellipse x:Name="OrbGlow"
               Width="72" Height="72"
               Fill="#20444444"/>
      <Ellipse x:Name="Orb"
               Width="48" Height="48"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               Fill="#444444"/>
    </Grid>

    <!-- Timer -->
    <TextBlock x:Name="TimerLabel"
               Text="00:00:00"
               FontSize="28" FontWeight="Light"
               Foreground="White"
               HorizontalAlignment="Center"
               Margin="0,0,0,6"/>

    <!-- Exit IP -->
    <TextBlock x:Name="ExitIpLabel"
               Text=""
               FontSize="11"
               Foreground="#5599FF"
               HorizontalAlignment="Center"
               Margin="0,0,0,24"/>

    <!-- Server IP input -->
    <TextBlock Text="SERVER IP" FontSize="10" Foreground="#666666"
               Margin="0,0,0,6"/>
    <TextBox x:Name="ServerIpBox"
             Watermark="0.0.0.0"
             Margin="0,0,0,16"/>

    <!-- Buttons -->
    <Button x:Name="ConnectBtn"
            Content="Connect"
            Classes="primary"
            HorizontalAlignment="Stretch"
            Margin="0,0,0,8"
            Click="OnConnect"/>
    <Button x:Name="DisconnectBtn"
            Content="Disconnect"
            Classes="secondary"
            HorizontalAlignment="Stretch"
            IsEnabled="False"
            Click="OnDisconnect"/>

    <!-- Retry hint -->
    <TextBlock x:Name="RetryLabel"
               Text=""
               FontSize="10"
               Foreground="#FF8844"
               HorizontalAlignment="Center"
               Margin="0,12,0,0"/>

  </StackPanel>
</Window>
